# *arr Ecosystem Dashboard — Environment Configuration
# Copy this file to .env.local and fill in your credentials.

# Service URLs (pre-configured for your instances)
RADARR_URL=https://jellyradarr-admin.opsec.rent
SONARR_URL=https://jellysonarr-admin.opsec.rent
PROWLARR_URL=https://jellyprowlarr-admin.opsec.rent
BAZARR_URL=https://jellybazarr.opsec.rent
JELLYSEERR_URL=https://jellyseerr.opsec.rent

# Global Basic Auth credentials (applied to all services)
ARR_BASIC_USER=
ARR_BASIC_PASS=

# Per-service Basic Auth credentials (override global if set)
# BASIC_USER_RADARR=
# BASIC_PASS_RADARR=
# BASIC_USER_SONARR=
# BASIC_PASS_SONARR=
# BASIC_USER_PROWLARR=
# BASIC_PASS_PROWLARR=
# BASIC_USER_BAZARR=
# BASIC_PASS_BAZARR=
# BASIC_USER_JELLYSEERR=
# BASIC_PASS_JELLYSEERR=

# API Keys — get these from each service's Settings > General > Security
# These are used alongside basic auth for API calls
RADARR_API_KEY=
SONARR_API_KEY=
PROWLARR_API_KEY=
BAZARR_API_KEY=
JELLYSEERR_API_KEY=

# Set to "true" to use mock data instead of real API calls
USE_MOCK_DATA=false
